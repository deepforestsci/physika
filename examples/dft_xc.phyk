# ============================================================
# DFT exchange-correlation functionals
# ============================================================
#
# Implements spin-paired LDA exchange-correlation functionals
# in Physika. Each functional returns [e, v] as a ℂ[2, m, k]
# array.

π = 3.141592653589793

#----------------------------------------------------------------
#   n    electron density on the full grid
#   rs   Wigner-Seitz radius
#   e    energy density (ex or ec)
#   v    potential (vx or vc)
#----------------------------------------------------------------

#------------------------------------------------------------------
# Slater exchange functional (spin-paired).
#
# Computes the local exchange energy density (ex) and exchange
# potential (vx) from the electron density via the Wigner-Seitz
# radius:
#
#   rs = (3 / 4πn)^(1/3)
#   ex = cx / rs
#   vx = (4/3) ex
#------------------------------------------------------------------

def lda_x(n: ℂ[k]): ℂ[2, k]:
    cx : ℝ = (-3.0 / 4.0) * (3.0 / (2.0 * π)) ** (2.0 / 3.0)   # Slater exchange constant
    rs : ℂ[k] = (3.0 / (4.0 * π * n)) ** (1.0 / 3.0)           # Wigner-Seitz radius
    ex : ℂ[k] = cx / rs                                         # exchange energy density
    vx : ℂ[k] = (4.0 / 3.0) * ex                               # exchange potential
    return [ex, vx]

#------------------------------------------------------------------
# Chachiyo correlation functional (spin-paired).
#
# Computes the local correlation energy density (ec) and correlation
# potential (vc) using Chachiyo's parametrization of the uniform
# electron gas.
#------------------------------------------------------------------

def lda_c_chachiyo(n: ℂ[k]): ℂ[2, k]:
    a : ℝ = -0.01554535   # Chachiyo fit parameter
    b : ℝ = 20.4562557    # Chachiyo fit parameter
    rs : ℂ[k] = (3.0 / (4.0 * π * n)) ** (1.0 / 3.0)                        # Wigner-Seitz radius
    ec : ℂ[k] = a * log(1.0 + b / rs + b / rs ** 2.0)                       # correlation energy density
    vc : ℂ[k] = ec + a * b * (2.0 + rs) / (3.0 * (b + b * rs + rs ** 2.0))  # correlation potential
    return [ec, vc]


#------------------------------------------------------------------
# Example: LDA exchange-correlation energy density and potential
# for the average electron density of the hydrogen atom example
# in dft_atoms.phyk.
#
# The hydrogen system contains one electron in a 16 Bohr cubic cell
# (Volume = 4096 Bohr³), giving a uniform average density
#
#     n0 = Nelectrons / Volume.
#------------------------------------------------------------------

# Average density n0:
n0 : ℝ = 1.0 / 4096.0

# To keep this example compact,
# the uniform density n0 is evaluated on four representative
# grid points.

n : ℂ[4] = [n0, n0, n0, n0]

# Slater exchange: returns [ex, vx]
ex_vx : ℂ[2, 4] = lda_x(n)
ex : ℂ[4] = ex_vx[0]
vx : ℂ[4] = ex_vx[1]

ex[0]                     # -0.046160: exchange energy density
vx[0]                     # -0.061547: exchange potential
ex[1]                     # -0.046160 (uniform density)
vx[1]                     # -0.061547

# Chachiyo correlation: returns [ec, vc]
ec_vc : ℂ[2, 4] = lda_c_chachiyo(n)
ec : ℂ[4] = ec_vc[0]
vc : ℂ[4] = ec_vc[1]

ec[0]                     # -0.018411: correlation energy density
vc[0]                     # -0.022337: correlation potential
ec[1]                     # -0.018411
vc[1]                     # -0.022337

# Total LDA exchange-correlation energy density and potential.
exc : ℂ[4] = ex + ec
vxc : ℂ[4] = vx + vc
exc[0]                    # -0.064571
vxc[0]                    # -0.083884