# -------------------------------------------
# Basic complex declarations
# -------------------------------------------
x : ℂ = 3 + 1j
y : ℂ = 5 + 3j
x
y

# -------------------------------------------
# Addition and Subtraction
# -------------------------------------------
complex_add: ℂ = x + y
complex_add

x - y



# -------------------------------------------
# Multiplication
# -------------------------------------------
# (3 + 1j) * (5 + 3j)
# 3 * (5 + 3j) + 1j * (5 + 3j)
# 15 + 9j + 5j + 3j**2
# 15 + 14j + 3j**2
# since, j**2 = -1
# 15 + 14j - 3
# 12 + 14j
# -------------------------------------------

complex_mul: ℂ = x * y
complex_mul


# -------------------------------------------
# complex in function (calculating magnitude)
# -------------------------------------------
# x = 3 + 1j 
# formula -> square_root(a**2 + b**2)
# a = 3
# b = 1
# square_root(9 + 1)
# square_root(10)
# -> 3.162
# -------------------------------------------
def magnitude(z: ℂ): ℂ:
    return abs(z)

magnitude(x)




# -------------------------------------------
# Array of complex numbers
# -------------------------------------------

array_imag: ℂ[3] = [1j, 2j, 3j]

array_complex: ℂ[3] = [1 + 9j, 7 + 2j, 3 + 5j]

nested_complex: ℂ[2, 2] = [
    [1 + 2j, 3 + 4j],
    [4 + 9j, 7 + 2j]
]


array_imag
array_complex
nested_complex