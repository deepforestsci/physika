a: Z2 = 1
b: Z2 = 0

# ----------------
# XOR operation
# ----------------
xor_opposite = a + b
xor_same = a + a

xor_opposite
xor_same

# ----------------
# AND operation
# ----------------
and_mixed = a * b
and_both_ones = a * a

and_mixed
and_both_ones


